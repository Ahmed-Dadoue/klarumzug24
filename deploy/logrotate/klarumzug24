# Klarumzug24 – Logrotate Configuration
# Install: cp /opt/klarumzug24/deploy/logrotate/klarumzug24 /etc/logrotate.d/klarumzug24

/opt/klarumzug24/logs/*.log {
    daily
    rotate 7
    compress
    delaycompress
    missingok
    notifempty
    create 0640 root root
    dateext
    dateformat -%Y%m%d
}
