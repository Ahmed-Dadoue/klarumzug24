# Backend runtime
DATABASE_URL=sqlite:////app/data/klarumzug.db
ADMIN_API_KEY=CHANGE_ME_SUPER_LONG_RANDOM_KEY
DEDUP_HOURS=6
ALLOWED_ORIGINS=https://klarumzug24.de,https://www.klarumzug24.de,http://localhost:8080

# Dode AI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
DODE_MODEL=gpt-4.1-mini
DODE_MAX_MESSAGES=12
DODE_MAX_OUTPUT_TOKENS=220

# SMTP notifications
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=CHANGE_ME_EMAIL_PASSWORD
MAIL_TO=notifications@example.com
MAIL_FROM=no-reply@example.com

# Optional frontend host port mapping for docker compose
FRONTEND_PORT=8080
