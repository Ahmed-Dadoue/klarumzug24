[Unit]
Description=Klarumzug24 FastAPI Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/klarumzug24/backend
EnvironmentFile=/opt/klarumzug24/backend/.env
ExecStart=/opt/klarumzug24/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 3
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
