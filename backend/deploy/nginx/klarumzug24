server {
    listen 80;
    server_name klarumzug24.de www.klarumzug24.de;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name klarumzug24.de www.klarumzug24.de;

    location = /api {
        return 301 /api/;
    }

    location = /impressum {
        return 301 /impressum.html;
    }

    location = /health {
        proxy_pass http://127.0.0.1:8000/health;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    root /var/www/html;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/klarumzug24.de/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/klarumzug24.de/privkey.pem;

    location ~* \.html$ {
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        expires -1;
        try_files $uri =404;
    }

    location ~* ^/assets/dode-chat\.(css|js)$ {
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        expires -1;
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
